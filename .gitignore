# Python virtual env & caches
.venv/
.uv-cache/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.pytest-tmp/
.ipynb_checkpoints/

# Model weights & large binary artifacts (regenerable / exceed GitHub file limits)
models/
*.safetensors
*.gguf
*.bin
*.pt
*.pth
*.npy
*.npz

# Serialized codec payloads (regenerable; small manifests/stats stay tracked)
*.stz
*.r4t12
*.density4
*.h51

# Streaming/scratch work dirs (HF cache, per-shard temporaries)
_stream_work/
_stz_synth/

# Logs & scratch
logs/
*.log
_locked_*/

# OS cruft
.DS_Store
Thumbs.db

# Probe run locks (live process state, never history)
*.lock

.env

# Local exploratory workspace; the published method lives under src/.
/research/

# Agent instruction files (local only)
CLAUDE.md
AGENTS.md
ORCHESTRATION.md
