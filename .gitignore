# Python virtual env & caches
.venv/
.uv-cache/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.pytest-tmp/
.ipynb_checkpoints/

# Model weights & large binary artifacts (regenerable / exceed GitHub file limits)
models/
*.safetensors
*.gguf
*.bin
*.pt
*.pth
*.npy
*.npz

# Serialized codec payloads (regenerable; small manifests/stats stay tracked)
*.stz
*.r4t12
*.density4
*.h51

# Streaming/scratch work dirs (HF cache, per-shard temporaries)
_stream_work/
_stz_synth/

# Logs & scratch
logs/
*.log
_locked_*/

# OS cruft
.DS_Store
Thumbs.db

# Probe run locks (live process state, never history)
*.lock

.env
research/notebook

# Per-row measurement dumps too large for GitHub (regenerable from the probe scripts)
research/candidates/0044-door12-fractional-bit-tans/artifacts/door12_rows_*.jsonl
research/candidates/0055-exporter-grid-normalization/tests/artifacts/b/*/per_violation.jsonl
research/candidates/0056-super120b-transfer/tests/artifacts/fetch56/support/per_context.jsonl.gz
